# Copy this file to stack.env (or enter these in Portainer's environment variables).
# Only use KEY=VALUE lines in env files.
# Do NOT put volume mappings like /host/path:/container/path in this file.

TZ=Europe/Amsterdam
PUID=100
PGID=1000
STRMNTR_HOST=0.0.0.0
STRMNTR_CONFIRM_DEL=MOBILE
STRMNTR_STATUS_FREQ=5
STRMNTR_LIST_FREQ=30
STREAMONITOR_IMAGE=ghcr.io/lossless1024/streamonitor:latest

# Host paths for bind mounts
DOWNLOADS_PATH=/volume1/Media/Media/media/cam
CONFIG_PATH=/volume2/Docker/streamonitor/config.json
CONTROLLER_PATH=/volume2/Docker/streamonitor/Controller.py
DOWNLOADER_PATH=/volume2/Docker/streamonitor/Downloader.py
PARAMETERS_PATH=/volume2/Docker/streamonitor/parameters.py
STRIPCHAT_KEYS_PATH=/volume2/Docker/streamonitor/stripchat_mouflon_keys.json

# Host web port -> container port 5000
WEB_PORT=5000
